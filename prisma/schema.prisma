generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ユーザー
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  passwordHash  String
  name          String
  nameKana      String?
  phone         String?
  address       String?
  role          String    @default("user") // user | admin
  affiliateCode String?   @unique          // アフィリエイトコード（例: cb_xK9m2pLq）
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  contracts     Contract[]
  spotOrders    SpotOrder[]
  payments      Payment[]
  emailLogs     EmailLog[]
  monthlySels   MonthlySelection[]
  inquiries     Inquiry[]
  lpGenerations LpGeneration[]
  comments      Comment[]
  passwordResetTokens PasswordResetToken[]
}

// コースマスタ
model Course {
  id                   String   @id @default(cuid())
  name                 String   @unique // StartUp / Standard / Enterprise / スポット
  type                 String   // subscription | spot
  monthlyFee           Int      // 月額（税別）
  initialFee           Int      // 初期費用（税別）
  maxCreationsPerMonth Int      // 月作成本数（0=スポット）
  languages            Int      // 対応言語数
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())

  contracts  Contract[]
}

// サブスク契約
model Contract {
  id                   String    @id @default(cuid())
  userId               String
  courseId             String
  status               String    @default("active") // active | cancelled | pending
  startDate            DateTime
  endDate              DateTime?
  nextBillingDate      DateTime
  stripeSubscriptionId String?   // mock
  cancelledAt          DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user             User               @relation(fields: [userId], references: [id])
  course           Course             @relation(fields: [courseId], references: [id])
  monthlySelections MonthlySelection[]
  orders           SpotOrder[]
}

// サブスク毎月の制作選択（動画 or LP）
model MonthlySelection {
  id          String   @id @default(cuid())
  contractId  String
  userId      String
  type        String   // video | lp
  targetMonth String   // YYYY-MM
  status      String   @default("pending") // pending | in_progress | completed
  createdAt   DateTime @default(now())

  contract Contract @relation(fields: [contractId], references: [id])
  user     User     @relation(fields: [userId], references: [id])
}

// スポット注文 / 追加オーダー
model SpotOrder {
  id             String   @id @default(cuid())
  userId         String
  contractId     String?  // 契約に紐づくオーダー（nullならスポット）
  type           String   // video | lp
  orderCategory  String   @default("spot") // spot | additional | contract
  status         String   @default("pending") // pending | in_progress | completed
  basePrice      Int      @default(0)
  extraMinutes   Int      @default(0)
  rushDelivery   Boolean  @default(false)
  totalPrice     Int      @default(0)
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id])
  contract      Contract?     @relation(fields: [contractId], references: [id])
  files         FileUpload[]
  lpGeneration  LpGeneration?
  comments      Comment[]
}

// ファイルアップロード
model FileUpload {
  id           String   @id @default(cuid())
  spotOrderId  String
  filename     String
  path         String
  uploadedBy   String   // user | admin
  createdAt    DateTime @default(now())

  spotOrder SpotOrder @relation(fields: [spotOrderId], references: [id])
}

// 決済履歴
model Payment {
  id              String   @id @default(cuid())
  userId          String
  amount          Int      // 税別金額
  type            String   // initial | monthly | spot | refund
  status          String   @default("pending") // pending | completed | failed
  stripePaymentId String?  // mock
  description     String?
  createdAt       DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// 問い合わせ
model Inquiry {
  id        String   @id @default(cuid())
  userId    String
  name      String
  message   String
  status    String   @default("new") // new | replied | closed
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// LPテンプレート
model LpTemplate {
  id          String   @id @default(cuid())
  name        String   @unique              // "Standard", "Review", "Ranking" 等
  description String?
  htmlBody    String   @db.Text             // {{placeholder}} 付きHTMLテンプレート
  cssBody     String?  @db.Text             // カスタムCSS
  thumbnail   String?                       // サムネイルURL
  sections    String   @default("[]") @db.Text  // JSON: セクション定義
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  lpGenerations LpGeneration[]
}

// LP生成
model LpGeneration {
  id              String    @id @default(cuid())
  spotOrderId     String    @unique
  userId          String
  templateId      String?
  status          String    @default("pending")
  // pending | reviewing | generating | editing | preview_ready | revision | approved | published | archived
  slug            String    @unique           // URL: /lp/[slug]

  // AI生成
  aiPrompt        String?   @db.Text
  aiRawOutput     String?   @db.Text

  // 生成コンテンツ
  generatedHtml   String?   @db.Text          // テンプレート+AI統合HTML
  editedHtml      String?   @db.Text          // 管理者編集版（優先）
  contentData     String?   @db.Text          // JSON: セクション別データ

  // アフィリエイト
  affiliateCode   String?                     // 生成時のスナップショット

  // メタ
  metaTitle       String?
  metaDescription String?
  ogImage         String?

  // 承認フロー
  revisionNotes   String?   @db.Text
  approvedAt      DateTime?
  publishedAt     DateTime?
  archivedAt      DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  spotOrder  SpotOrder    @relation(fields: [spotOrderId], references: [id])
  user       User         @relation(fields: [userId], references: [id])
  template   LpTemplate?  @relation(fields: [templateId], references: [id])
}

// コメント（オーダーに紐づくユーザー/管理者間メッセージ）
model Comment {
  id          String   @id @default(cuid())
  spotOrderId String
  userId      String
  role        String   // user | admin
  message     String   @db.Text
  createdAt   DateTime @default(now())

  spotOrder SpotOrder @relation(fields: [spotOrderId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
}

// パスワードリセットトークン
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

// メール送信ログ
model EmailLog {
  id           String   @id @default(cuid())
  userId       String
  templateType String   // account_created | info_changed | course_changed | course_added | course_cancelled | order_added | account_cancelled
  sentAt       DateTime @default(now())
  status       String   @default("sent") // sent | failed

  user User @relation(fields: [userId], references: [id])
}
